# PostgreSQL configuration for Prisma.
# Keep the real DATABASE_URL only in .env.local, Vercel Environment Variables, or another secret manager.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/agritech_academy?schema=public"

# Clerk OAuth Google configuration for the future Next.js integration.
# Public key is safe for the browser; keep CLERK_SECRET_KEY only on the server.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Academy auth redirects
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/academy/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/academy/register
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/academy/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/academy/dashboard

# Payment configuration (server-side values only; do not expose provider secrets to the browser).
# Use dev-simulated locally, then paypal or moncash in production when credentials/webhooks are configured.
PAYMENT_PROVIDER=
NEXT_PUBLIC_APP_URL=http://localhost:3000
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_MODE=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
