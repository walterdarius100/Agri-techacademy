{
  "name": "agri-techacademy",
  "version": "1.0.0",
  "private": true,
  "description": "Fondation web et academy pour Agri-Tech.",
  "scripts": {
    "dev": "next dev",
    "build": "npm run check && next build",
    "start": "next start",
    "check": "npm run prisma:validate && node --check prisma/seed.js",
    "prisma:generate": "sh -c 'DATABASE_URL=${DATABASE_URL:-postgresql://user:password@db:5432/agritech_academy?schema=public} prisma generate'",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:validate": "sh -c 'DATABASE_URL=${DATABASE_URL:-postgresql://user:password@db:5432/agritech_academy?schema=public} prisma validate'"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "next": "^16.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "prisma": "^6.0.0",
    "typescript": "^5.9.0",
    "@types/react-dom": "^19.2.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
