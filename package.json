{
  "name": "agri-techacademy",
  "version": "1.0.0",
  "private": true,
  "description": "Fondation web et academy pour Agri-Tech.",
  "scripts": {
    "check": "npm run prisma:validate && node --check prisma/seed.js",
    "prisma:generate": "node scripts/prisma-generate-safe.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:validate": "node scripts/prisma-generate-safe.js validate",
    "build": "node scripts/prisma-generate-safe.js && next build",
    "dev": "next dev",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@prisma/client": "6.0.0",
    "next": "^15.5.6",
    "prisma": "6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
